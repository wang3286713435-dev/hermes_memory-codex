APP_NAME=Hermes Memory
APP_ENV=local
APP_DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://hermes:hermes@postgres:5432/hermes_memory
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX_CHUNKS=hermes_chunks

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=hermes
MINIO_SECRET_KEY=hermes-secret
MINIO_BUCKET_DOCUMENTS=hermes-documents
MINIO_SECURE=false
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage/documents

VECTOR_STORE_PROVIDER=qdrant
VECTOR_DIMENSION=1024
VECTOR_STORE_URL=
VECTOR_STORE_API_KEY=

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hermes_chunks
QDRANT_VECTOR_SIZE=1024

EMBEDDING_PROVIDER=aliyun
# Model Studio keys may be shared. If ALIYUN_RERANK_API_KEY is empty,
# rerank automatically falls back to ALIYUN_EMBEDDING_API_KEY.
ALIYUN_EMBEDDING_API_KEY=
ALIYUN_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding
ALIYUN_EMBEDDING_MODEL=text-embedding-v3
ALIYUN_EMBEDDING_DIMENSION=1024

RERANK_PROVIDER=noop
RERANK_ENABLED=false
RERANK_DEFAULT_ENABLEMENT_ENABLED=false
RERANK_DEFAULT_ENABLEMENT_SOURCE_TYPES=tender
RERANK_DEFAULT_ENABLEMENT_ROUTE_TYPES=tender,tender_qa,tender_query
RERANK_DEFAULT_ENABLEMENT_KEYWORDS=资质,要求,条款,截止,联合体,投标,招标,开标,答疑,评分,保证金
RERANK_DEFAULT_ENABLEMENT_MIN_CANDIDATES=2
RERANK_INPUT_CAP=30
RERANK_URL=http://reranker:8080/rerank
# Optional dedicated rerank key. Leave empty to reuse ALIYUN_EMBEDDING_API_KEY.
ALIYUN_RERANK_API_KEY=
ALIYUN_RERANK_BASE_URL=https://dashscope.aliyuncs.com
ALIYUN_RERANK_MODEL=gte-rerank-v2
# Phase 2.5 default gray timeout. Timeout or provider errors always fail-open.
ALIYUN_RERANK_TIMEOUT_MS=600

LOG_LEVEL=INFO
DB_AUTO_CREATE_TABLES=true
